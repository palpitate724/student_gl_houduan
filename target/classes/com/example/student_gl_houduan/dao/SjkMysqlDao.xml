<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.student_gl_houduan.dao.SjkMysqlDao">

    <!-- 登录查询-->
    <select id="login" resultType="com.example.student_gl_houduan.model.UserStu">
        select * from student_gl_name_password
        <where>
            <if test="userstu.sid!=null and userstu.spassword!=null">
                sid=#{userstu.sid} and spassword=#{userstu.spassword} and sdelect=0
            </if>
            <if test="userstu.spassword==null">
                sid=#{userstu.sid} and sdelect=0
            </if>
        </where>
    </select>

    <!--注册_数据写入-->
    <insert id="signup">
        insert into student_gl_name_password (sid,sname,spassword,sjiaose)
        values(#{userstu.sid},#{userstu.sname},#{userstu.spassword},#{userstu.sjiaose})
    </insert>

    <!--学生信息查询-->
    <select id="stuSelect" resultType="com.example.student_gl_houduan.model.UserStuInto">
        select * from student_gl_sid
        <where>
            <if test="userstuinto.sid!=null and userstuinto.sid!=''">
                sid=#{userstuinto.sid}
            </if>
            <if test="userstuinto.sname!=null and userstuinto.sname!=''">
                AND sname= #{userstuinto.sname}
            </if>
            <if test="userstuinto.sage!=null and userstuinto.sage!=''">
                AND sage= #{userstuinto.sage}
            </if>
            <if test="userstuinto.ssex!=null and userstuinto.ssex!=''">
                AND ssex= #{userstuinto.ssex}
            </if>
            <if test="userstuinto.ssion!=null and userstuinto.ssion!=''">
                AND ssion= #{userstuinto.ssion}
            </if>
            AND sdelect=0
        </where>
    </select>

    <!--学生信息添加-->
    <insert id="studentInto">
        insert into student_gl_sid (sid,sname,sage,ssex,ssion)
        values(#{userstuinto.sid},#{userstuinto.sname},#{userstuinto.sage},#{userstuinto.ssex},#{userstuinto.ssion})
    </insert>

    <!--学生信息修改-->
    <update id="studentUpdate">
        update student_gl_sid
        <set>
            <if test="userstuinto.sname!=null">
                sname=#{userstuinto.sname},
            </if>
            <if test="userstuinto.sage!=null">
                sage=#{userstuinto.sage},
            </if>
            <if test="userstuinto.ssex!=null">
                ssex=#{userstuinto.ssex},
            </if>
            <if test="userstuinto.ssion!=null">
                ssion=#{userstuinto.ssion},
            </if>
        </set>
        <where>
            sid=#{userstuinto.sid}
        </where>
    </update>

    <!--学生信息删除--><!-- 逻辑删除/软删除-->
    <update id="studentDelete">
        update student_gl_sid
        set sdelect=1
        <where>
            sid=#{userstuinto.sid}
        </where>
    </update>

</mapper>